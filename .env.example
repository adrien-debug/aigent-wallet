# Optional: protect /api/v1 with Bearer auth (recommended in staging/production).
# Example: curl -H "Authorization: Bearer your-secret" https://host/api/v1/metrics
AIGENT_API_KEY=

# Optional: browser clients — exact origin allowed for CORS (must match fetch Origin).
# Example: https://aigent-wallet.vercel.app
AIGENT_CORS_ORIGIN=

# Supabase (optional) — Auth session refresh via middleware + OAuth/magic link callback.
# Project URL and anon key: Supabase Dashboard → Project Settings → API.
# Vercel Preview + Supabase Branching: set these to the branch project URL/anon key for preview envs.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
